{
  "$schema": "https://opencode.ai/config.json",
  "model": "omlx/{{PRIMARY_MODEL_ID}}",
  "small_model": "ollama/qwen2.5-coder:14b",
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "{{OMLX_API_KEY}}"
      },
      "models": {
        "{{PRIMARY_MODEL_ID}}": {
          "name": "Primary local model",
          "tools": true
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5 Coder 14B",
          "tools": true
        }
      }
    }
  }
}
